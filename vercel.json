{
  "outputDirectory": "dist/client",
  "buildCommand": "npm run build:ssg",
  "rewrites": [
    {
      "source": "/os",
      "destination": "https://assist-tech-rouge.vercel.app/"
    },
    {
      "source": "/os/:path*",
      "destination": "https://assist-tech-rouge.vercel.app/:path*"
    },
    {
      "source": "/WEX.png",
      "destination": "https://assist-tech-rouge.vercel.app/WEX.png"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://assist-tech-rouge.vercel.app/assets/:path*"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|logo\\.png).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
